# ── Modulador de Tensão Dual ──────────────────────────────────────────────
def medir_coerencia(freq_componentes, phi=PHI):
    """
    Mede coerência de amplitude + fase de um conjunto de componentes.
    Retorna valor per-sample entre 0 e 1.
    """
    if freq_componentes.shape[-1] < 2:
        return np.zeros((freq_componentes.shape[0], 1))

    # Amplitude — presença
    amplitude = np.abs(freq_componentes)
    amp_norm  = amplitude / (amplitude.sum(axis=-1, keepdims=True) + 1e-8)
    entropia  = -np.sum(amp_norm * np.log(amp_norm + 1e-8), axis=-1, keepdims=True)
    coer_amp  = 1.0 - entropia / np.log(max(freq_componentes.shape[-1], 2))

    # Fase — trajetória
    fase       = np.angle(freq_componentes)
    resultante = np.sqrt(
        np.cos(fase).mean(axis=-1, keepdims=True)**2 +
        np.sin(fase).mean(axis=-1, keepdims=True)**2
    )

    # Combinação amplitude + fase
    return (coer_amp + resultante) / 2.0


def tensao_dual_modulator(x, phi=PHI, alpha=ALPHA):
    """
    Modulador de Tensão Dual.

    Separa o espectro em duas tensões opostas e simétricas:

    Tensão ASCENDENTE — frequências positivas [1 : n//2]
      Representa energia crescente — padrões que "sobem"
      φ aplicado à coerência ascendente

    Tensão DESCENDENTE — frequências negativas [n//2 : n]
      Representa energia decrescente — padrões que "descem"
      φ aplicado à coerência descendente

    α como operador REAL de equilíbrio:
      modulador = alpha * mod_asc + (1-alpha) * mod_desc

    α ≈ 0.0073 — a tensão ascendente tem peso muito menor
    que a descendente — exatamente como na estrutura fina:
    absorção de fóton é muito menos provável que emissão.
    """
    freq = np.fft.fft(x, axis=-1)
    n    = x.shape[-1]

    # TENSÃO ASCENDENTE — frequências positivas
    # Componentes 1 até n//2 — energia crescente
    freq_asc = freq[:, 1:n//2]

    # TENSÃO DESCENDENTE — frequências negativas
    # Componentes n//2 até n — energia decrescente
    freq_desc = freq[:, n//2:]

    # Coerência de cada tensão
    coer_asc  = medir_coerencia(freq_asc,  phi)
    coer_desc = medir_coerencia(freq_desc, phi)

    # φ aplicado a cada tensão separadamente
    mod_asc  = phi * np.tanh(coer_asc  * phi)
    mod_desc = phi * np.tanh(coer_desc * phi)

    # α COMO OPERADOR REAL DE EQUILÍBRIO
    # α = 1/137 — peso da tensão ascendente
    # 1-α ≈ 0.993 — peso da tensão descendente
    # Assim como α define a probabilidade de absorção vs emissão
    modulador = alpha * mod_asc + (1 - alpha) * mod_desc

    return modulador, mod_asc, mod_desc, coer_asc, coer_desc


def relu(x): return np.maximum(0, x)
def relu_deriv(x): return (x > 0).astype(float)
def sigmoid(x): return 1.0 / (1.0 + np.exp(-np.clip(x, -500, 500)))
def clip_grad(g, max_norm=1.0):
    norm = np.linalg.norm(g)
    return g * max_norm / norm if norm > max_norm else g

uniform_layers = [144, 144, 144]

class NeuralNet:
    def __init__(self, layer_sizes, mode='conv', seed=42):
        np.random.seed(seed)
        self.mode    = mode
        self.weights = []
        self.biases  = []
        for i in range(len(layer_sizes)-1):
            scale = np.sqrt(2.0 / layer_sizes[i])
            self.weights.append(np.random.randn(layer_sizes[i], layer_sizes[i+1]) * scale)
            self.biases.append(np.zeros(layer_sizes[i+1]))

    def forward(self, X):
        self.pre_acts = []; self.acts = [X]; cur = X
        for i, (W, b) in enumerate(zip(self.weights, self.biases)):
            is_out = (i == len(self.weights)-1)
            z = cur @ W + b
            cur = sigmoid(z) if is_out else relu(z)
            self.pre_acts.append(z); self.acts.append(cur)
        return cur

    def backward(self, X, y, lr=0.1, permuted=False):
        m = X.shape[0]
        if self.mode == 'dual':
            X_mod = X[np.random.permutation(len(X))] if permuted else X
            mod, _, _, _, _ = tensao_dual_modulator(X_mod)
            lr_efetivo = lr * mod.mean()
        else:
            lr_efetivo = lr

        delta = self.acts[-1] - y.reshape(-1, 1)
        for i in reversed(range(len(self.weights))):
            dW = clip_grad(self.acts[i].T @ delta / m, 1.0)
            db = clip_grad(delta.mean(axis=0), 1.0)
            self.weights[i] -= lr_efetivo * dW
            self.biases[i]  -= lr_efetivo * db
            if i > 0:
                delta = (delta @ self.weights[i].T) * relu_deriv(self.pre_acts[i-1])

    def predict(self, X): return (self.forward(X).flatten() >= 0.5).astype(int)
    def accuracy(self, X, y): return np.mean(self.predict(X) == y)

# ── Carregar SST-2 ────────────────────────────────────────────────────────
print("\nCarregando SST-2...")
dataset = load_dataset('glue', 'sst2')
encoder = SentenceTransformer('all-MiniLM-L6-v2')

N_TRAIN = 5000
X_train = encoder.encode(dataset['train']['sentence'][:N_TRAIN],
                         show_progress_bar=True, batch_size=64)
y_train = np.array(dataset['train']['label'][:N_TRAIN])
X_val   = encoder.encode(dataset['validation']['sentence'],
                         show_progress_bar=True, batch_size=64)
y_val   = np.array(dataset['validation']['label'])

mean = X_train.mean(0); std = X_train.std(0) + 1e-8
X_train = (X_train - mean) / std
X_val   = (X_val   - mean) / std
print(f"X_train: {X_train.shape}  X_val: {X_val.shape}")

# ── Diagnóstico das Duas Tensões ──────────────────────────────────────────
print("\n=== DIAGNÓSTICO — TENSÃO DUAL ===")
sample = X_train[:200]
mod, mod_asc, mod_desc, coer_asc, coer_desc = tensao_dual_modulator(sample)

print(f"Tensão ASCENDENTE (freq. positivas [1:{X_train.shape[-1]//2}]):")
print(f"  Coerência média : {coer_asc.mean():.4f} ± {coer_asc.std():.4f}")
print(f"  Modulador φ     : {mod_asc.mean():.4f} ± {mod_asc.std():.4f}")

print(f"\nTensão DESCENDENTE (freq. negativas [{X_train.shape[-1]//2}:{X_train.shape[-1]}]):")
print(f"  Coerência média : {coer_desc.mean():.4f} ± {coer_desc.std():.4f}")
print(f"  Modulador φ     : {mod_desc.mean():.4f} ± {mod_desc.std():.4f}")

print(f"\nModulador Dual (α·asc + (1-α)·desc):")
print(f"  Média={mod.mean():.4f}  Desvio={mod.std():.4f}")
print(f"  Mín={mod.min():.4f}  Máx={mod.max():.4f}")
print(f"  Variação total: {mod.max()-mod.min():.4f}")

print(f"\nDiferença entre tensões:")
diff = mod_asc - mod_desc
print(f"  asc - desc: média={diff.mean():.6f} ± {diff.std():.6f}")
print(f"  As tensões são {'diferentes' if diff.std() > 0.001 else 'muito similares'}")

# ── Permutation Test — 20 Seeds ───────────────────────────────────────────
N_SEEDS    = 20
N_EPOCHS   = 10
LR         = 0.1
BATCH_SIZE = 128

rng   = np.random.RandomState(int(time.time()) % 100000)
SEEDS = rng.randint(0, 99999, size=N_SEEDS).tolist()

print(f"\nSeeds por timestamp: {SEEDS}")
print()

arch = [384] + uniform_layers + [1]

res_dual = []
res_perm = []
res_conv = []

print(f"{'Seed':>8} | {'Dual':>8} | {'Permut.':>8} | {'Conv':>8} | {'Genuíno?':>9}")
print("-" * 55)

for seed in SEEDS:
    net_dual = NeuralNet(arch, mode='dual', seed=seed)
    net_perm = NeuralNet(arch, mode='dual', seed=seed)
    net_conv = NeuralNet(arch, mode='conv', seed=seed)

    n_batches = len(X_train) // BATCH_SIZE

    for epoch in range(N_EPOCHS):
        idx = np.random.RandomState(seed + epoch).permutation(len(X_train))
        Xs, ys = X_train[idx], y_train[idx]
        for b in range(n_batches):
            Xb = Xs[b*BATCH_SIZE:(b+1)*BATCH_SIZE]
            yb = ys[b*BATCH_SIZE:(b+1)*BATCH_SIZE]
            net_dual.forward(Xb); net_dual.backward(Xb, yb, lr=LR, permuted=False)
            net_perm.forward(Xb); net_perm.backward(Xb, yb, lr=LR, permuted=True)
            net_conv.forward(Xb); net_conv.backward(Xb, yb, lr=LR)

    a_d = net_dual.accuracy(X_val, y_val)
    a_p = net_perm.accuracy(X_val, y_val)
    a_c = net_conv.accuracy(X_val, y_val)

    res_dual.append(a_d)
    res_perm.append(a_p)
    res_conv.append(a_c)

    genuino = "✅ SIM" if a_d > a_p else "❌ NÃO"
    print(f"{seed:>8} | {a_d:>8.4f} | {a_p:>8.4f} | {a_c:>8.4f} | {genuino:>9}")

# ── Resultados ────────────────────────────────────────────────────────────
dual_arr = np.array(res_dual)
perm_arr = np.array(res_perm)
conv_arr = np.array(res_conv)

_, p_dp = ttest_ind(dual_arr, perm_arr)
_, p_dc = ttest_ind(dual_arr, conv_arr)
wins_dp = int(np.sum(dual_arr > perm_arr))
wins_dc = int(np.sum(dual_arr > conv_arr))

print("=" * 65)
print("  TENSÃO DUAL — RESULTADOS")
print("  α como operador real de equilíbrio entre duas tensões")
print("=" * 65)
print(f"  Dual Real    : {dual_arr.mean()*100:.2f}% +/- {dual_arr.std()*100:.2f}%")
print(f"  Dual Permut. : {perm_arr.mean()*100:.2f}% +/- {perm_arr.std()*100:.2f}%")
print(f"  Conv puro    : {conv_arr.mean()*100:.2f}% +/- {conv_arr.std()*100:.2f}%")
print()
print(f"  Dual vs Permut. : {(dual_arr-perm_arr).mean()*100:+.2f}% · p={p_dp:.4f} · {wins_dp}/20")
print(f"  Dual vs Conv    : {(dual_arr-conv_arr).mean()*100:+.2f}% · p={p_dc:.4f} · {wins_dc}/20")
print()
print(f"\n  COMPARAÇÃO EVOLUTIVA:")
print(f"  Conv puro:            ~69.5% ± 3.3%  baseline")
print(f"  Espectral φ flat:     ~72.8% ± 1.2%  +3.3%")
print(f"  Octave Concessional:  ~75.5% ± 1.0%  +6.1%")
print(f"  φ-Symmetric:          ~76.0% ± 0.8%  +6.5%")
print(f"  Tensão Dual:          {dual_arr.mean()*100:.2f}% ± {dual_arr.std()*100:.2f}%  {(dual_arr.mean()-conv_arr.mean())*100:+.2f}%")
print()

if (dual_arr.mean() > perm_arr.mean()) and p_dp < 0.05:
    print("  ✅ TENSÃO DUAL GENUÍNA!")
    print("  α como operador distingue real de permutado!")
    print("  As duas tensões carregam assinatura individual.")
elif dual_arr.mean() <= perm_arr.mean():
    print("  ❌ Ainda não distingue real de permutado")
    print("  O substrato BERT normalizado continua sendo o limitante.")
else:
    print("  ⚠️  TENDÊNCIA — ampliar seeds")
print("=" * 65)

