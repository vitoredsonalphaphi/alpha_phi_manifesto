# ── Divisão φ-Simétrica do Espectro ──────────────────────────────────────
def gerar_bandas_phi(n_componentes, n_niveis=4):
    """
    Divide o espectro em bandas pela proporção φ recursivamente.
    
    Nível 1: [0 : n×0.618] e [n×0.618 : n]
    Nível 2: cada metade dividida novamente por φ
    ...
    
    É a bifurcação de Fibonacci aplicada ao espectro.
    Cada divisão preserva a proporção áurea.
    """
    bandas = []
    
    def dividir_recursivo(inicio, fim, nivel):
        if nivel == 0 or fim - inicio < 2:
            bandas.append((inicio, fim))
            return
        
        # Divide na proporção φ — 61.8% para baixas, 38.2% para altas
        meio = inicio + int((fim - inicio) / PHI)
        
        # Recursão nas duas metades
        dividir_recursivo(inicio, meio, nivel - 1)
        dividir_recursivo(meio, fim, nivel - 1)
    
    dividir_recursivo(0, n_componentes // 2, n_niveis)
    return bandas


def medir_coerencia_banda(freq_banda):
    """Mede coerência amplitude + fase em uma banda."""
    if freq_banda.shape[-1] < 2:
        return np.zeros((freq_banda.shape[0], 1))
    
    # Amplitude
    amplitude = np.abs(freq_banda)
    amp_norm  = amplitude / (amplitude.sum(axis=-1, keepdims=True) + 1e-8)
    entropia  = -np.sum(amp_norm * np.log(amp_norm + 1e-8), axis=-1, keepdims=True)
    coer_amp  = 1.0 - entropia / np.log(max(freq_banda.shape[-1], 2))
    
    # Fase — α como trajetória
    fase       = np.angle(freq_banda)
    resultante = np.sqrt(
        np.cos(fase).mean(axis=-1, keepdims=True)**2 +
        np.sin(fase).mean(axis=-1, keepdims=True)**2
    )
    
    # α como operador de granularidade
    return (1.0 - ALPHA) * coer_amp + ALPHA * resultante


def phi_symmetric_modulator(x, phi=PHI, n_niveis=4):
    """
    Phi-Symmetric Spectral Modulator.
    
    Divide o espectro recursivamente na proporção φ.
    Cada banda recebe peso proporcional ao seu nível na hierarquia φ.
    
    Diferença do GSN: não usa 50/50 — usa 61.8/38.2
    Diferença do Octave atual: não usa oitavas fixas — usa divisão φ
    
    É a proporção áurea aplicada à própria distribuição de energia.
    """
    freq  = np.fft.fft(x, axis=-1)
    n     = x.shape[-1]
    
    # Gera bandas pela proporção φ recursivamente
    bandas = gerar_bandas_phi(n, n_niveis)
    
    # Calcula coerência em cada banda
    coerencias = []
    pesos      = []
    
    for i, (ini, fim) in enumerate(bandas):
        if fim > ini:
            banda = freq[:, ini:fim]
            coer  = medir_coerencia_banda(banda)
            coerencias.append(coer)
            # Peso φ-proporcional: bandas mais baixas têm peso maior
            # seguindo a proporção áurea
            peso = (1.0 / PHI) ** i
            pesos.append(peso)
    
    if not coerencias:
        return np.ones((x.shape[0], 1)) * phi * np.tanh(0.5 * phi)
    
    # Normaliza pesos
    pesos_arr = np.array(pesos)
    pesos_arr = pesos_arr / pesos_arr.sum()
    
    coer_stack = np.concatenate(coerencias, axis=-1)  # (batch, n_bandas)
    
    # SIMETRIA φ: combinação ponderada pela proporção áurea
    # Não descarta nenhuma banda — todas contribuem na proporção φ
    coer_ponderada = (coer_stack * pesos_arr).sum(axis=-1, keepdims=True)
    
    # Concessão: também considera a melhor banda disponível
    coer_maxima = coer_stack.max(axis=-1, keepdims=True)
    
    # Híbrido φ-simétrico: ponderada (harmonia φ) + máxima (concessão)
    # Proporção entre elas? Naturalmente: φ e 1/φ
    coer_final = (1.0/PHI) * coer_ponderada + (1.0/PHI**2) * coer_maxima

    modulador = phi * np.tanh(coer_final * phi)
    
    return modulador, coer_stack, bandas, pesos_arr


def relu(x): return np.maximum(0, x)
def relu_deriv(x): return (x > 0).astype(float)
def sigmoid(x): return 1.0 / (1.0 + np.exp(-np.clip(x, -500, 500)))
def clip_grad(g, max_norm=1.0):
    norm = np.linalg.norm(g)
    return g * max_norm / norm if norm > max_norm else g

uniform_layers = [144, 144, 144]

class NeuralNet:
    def __init__(self, layer_sizes, mode='conv', seed=42):
        np.random.seed(seed)
        self.mode    = mode
        self.weights = []
        self.biases  = []
        for i in range(len(layer_sizes)-1):
            scale = np.sqrt(2.0 / layer_sizes[i])
            self.weights.append(np.random.randn(layer_sizes[i], layer_sizes[i+1]) * scale)
            self.biases.append(np.zeros(layer_sizes[i+1]))

    def forward(self, X):
        self.pre_acts = []; self.acts = [X]; cur = X
        for i, (W, b) in enumerate(zip(self.weights, self.biases)):
            is_out = (i == len(self.weights)-1)
            z = cur @ W + b
            cur = sigmoid(z) if is_out else relu(z)
            self.pre_acts.append(z); self.acts.append(cur)
        return cur

    def backward(self, X, y, lr=0.1, permuted=False):
        m = X.shape[0]
        if self.mode == 'phi_sym':
            X_mod = X[np.random.permutation(len(X))] if permuted else X
            mod, _, _, _ = phi_symmetric_modulator(X_mod)
            lr_efetivo = lr * mod.mean()
        else:
            lr_efetivo = lr

        delta = self.acts[-1] - y.reshape(-1, 1)
        for i in reversed(range(len(self.weights))):
            dW = clip_grad(self.acts[i].T @ delta / m, 1.0)
            db = clip_grad(delta.mean(axis=0), 1.0)
            self.weights[i] -= lr_efetivo * dW
            self.biases[i]  -= lr_efetivo * db
            if i > 0:
                delta = (delta @ self.weights[i].T) * relu_deriv(self.pre_acts[i-1])

    def predict(self, X): return (self.forward(X).flatten() >= 0.5).astype(int)
    def accuracy(self, X, y): return np.mean(self.predict(X) == y)

