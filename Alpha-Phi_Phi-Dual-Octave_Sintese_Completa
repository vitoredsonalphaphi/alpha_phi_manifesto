# ── Funções Base ──────────────────────────────────────────────────────────
def gerar_bandas_phi(n, n_niveis=3):
    bandas = []
    def dividir(ini, fim, nivel):
        if nivel == 0 or fim - ini < 2:
            bandas.append((ini, fim))
            return
        meio = ini + int((fim - ini) / PHI)
        dividir(ini, meio, nivel - 1)
        dividir(meio, fim, nivel - 1)
    dividir(0, n, n_niveis)
    return bandas

def coerencia_banda(freq, phi=PHI):
    if freq.shape[-1] < 2:
        return np.zeros((freq.shape[0], 1))
    amp      = np.abs(freq)
    amp_norm = amp / (amp.sum(axis=-1, keepdims=True) + 1e-8)
    ent      = -np.sum(amp_norm * np.log(amp_norm + 1e-8), axis=-1, keepdims=True)
    c_amp    = 1.0 - ent / np.log(max(freq.shape[-1], 2))
    fase     = np.angle(freq)
    res      = np.sqrt(np.cos(fase).mean(axis=-1, keepdims=True)**2 +
                      np.sin(fase).mean(axis=-1, keepdims=True)**2)
    return (c_amp + res) / 2.0

# ── Modulador Phi-Dual-Octave ─────────────────────────────────────────────
def phi_dual_octave_modulator(x, phi=PHI, alpha=ALPHA, n_niveis=3):
    """
    Síntese Completa — quatro elementos:

    1. Tensão Dual: separa freq. positivas (asc) e negativas (desc)
    2. φ-Recursive: divide cada tensão em bandas φ-proporcionais
    3. Octave Concessional: melhor banda por amostra (não descarta)
    4. Regra do Octeto: primeiras 8 freq. recebem peso especial
       como camada de valência — âncora de coerência fundamental
    """
    freq = np.fft.fft(x, axis=-1)
    n    = x.shape[-1]

    resultados = {}

    for nome, freq_tensao in [('asc', freq[:, 1:n//2]),
                               ('desc', freq[:, n//2:])]:
        nt     = freq_tensao.shape[-1]
        bandas = gerar_bandas_phi(nt, n_niveis)

        coers  = []
        pesos  = []

        for i, (ini, fim) in enumerate(bandas):
            if fim > ini:
                c    = coerencia_banda(freq_tensao[:, ini:fim], phi)
                coers.append(c)
                # Peso φ-proporcional base
                peso = (1.0 / phi) ** i
                # REGRA DO OCTETO: primeiras 8 freq. recebem peso extra
                # Analogia com camada de valência — âncora de estabilidade
                if ini < OCTETO:
                    peso *= phi  # amplifica as fundamentais
                pesos.append(peso)

        if not coers:
            resultados[nome] = np.ones((x.shape[0], 1)) * 0.5
            continue

        pesos_arr  = np.array(pesos) / sum(pesos)
        coer_stack = np.concatenate(coers, axis=-1)

        # φ-Symmetric: coerência ponderada pelas proporções φ
        coer_pond = (coer_stack * pesos_arr).sum(axis=-1, keepdims=True)

        # Octave Concessional: melhor banda disponível por amostra
        coer_max  = coer_stack.max(axis=-1, keepdims=True)

        # Síntese: ponderada (harmonia) + máxima (concessão)
        coer_final = (1.0/phi) * coer_pond + (1.0/phi**2) * coer_max

        resultados[nome] = phi * np.tanh(coer_final * phi)

    mod_asc  = resultados['asc']
    mod_desc = resultados['desc']

    # α como operador de equilíbrio entre as duas tensões
    modulador = alpha * mod_asc + (1 - alpha) * mod_desc

    return modulador, mod_asc, mod_desc


def relu(x): return np.maximum(0, x)
def relu_deriv(x): return (x > 0).astype(float)
def sigmoid(x): return 1.0 / (1.0 + np.exp(-np.clip(x, -500, 500)))
def clip_grad(g, max_norm=1.0):
    norm = np.linalg.norm(g)
    return g * max_norm / norm if norm > max_norm else g

uniform_layers = [144, 144, 144]

class NeuralNet:
    def __init__(self, layer_sizes, mode='conv', seed=42):
        np.random.seed(seed)
        self.mode    = mode
        self.weights = []
        self.biases  = []
        for i in range(len(layer_sizes)-1):
            scale = np.sqrt(2.0 / layer_sizes[i])
            self.weights.append(np.random.randn(layer_sizes[i], layer_sizes[i+1]) * scale)
            self.biases.append(np.zeros(layer_sizes[i+1]))

    def forward(self, X):
        self.pre_acts = []; self.acts = [X]; cur = X
        for i, (W, b) in enumerate(zip(self.weights, self.biases)):
            is_out = (i == len(self.weights)-1)
            z = cur @ W + b
            cur = sigmoid(z) if is_out else relu(z)
            self.pre_acts.append(z); self.acts.append(cur)
        return cur

    def backward(self, X, y, lr=0.1, permuted=False):
        m = X.shape[0]
        if self.mode == 'pdo':
            X_mod = X[np.random.permutation(len(X))] if permuted else X
            mod, _, _ = phi_dual_octave_modulator(X_mod)
            lr_efetivo = lr * mod.mean()
        else:
            lr_efetivo = lr

        delta = self.acts[-1] - y.reshape(-1, 1)
        for i in reversed(range(len(self.weights))):
            dW = clip_grad(self.acts[i].T @ delta / m, 1.0)
            db = clip_grad(delta.mean(axis=0), 1.0)
            self.weights[i] -= lr_efetivo * dW
            self.biases[i]  -= lr_efetivo * db
            if i > 0:
                delta = (delta @ self.weights[i].T) * relu_deriv(self.pre_acts[i-1])

    def predict(self, X): return (self.forward(X).flatten() >= 0.5).astype(int)
    def accuracy(self, X, y): return np.mean(self.predict(X) == y)

