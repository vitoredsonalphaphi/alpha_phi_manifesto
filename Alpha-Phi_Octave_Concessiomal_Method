    print(f"  Oitava {i+1}: {pct:.1f}% das amostras")

# ── Permutation Test — 20 Seeds ───────────────────────────────────────────
N_SEEDS    = 20
N_EPOCHS   = 10
LR         = 0.1
BATCH_SIZE = 128

rng   = np.random.RandomState(int(time.time()) % 100000)
SEEDS = rng.randint(0, 99999, size=N_SEEDS).tolist()

print(f"\nSeeds por timestamp: {SEEDS}")
print()

arch = [384] + uniform_layers + [1]

res_oct  = []
res_perm = []
res_conv = []

print(f"{'Seed':>8} | {'Octave':>8} | {'Permut.':>8} | {'Conv':>8} | {'Genuíno?':>9}")
print("-" * 55)

for seed in SEEDS:
    net_oct  = NeuralNet(arch, mode='octave', seed=seed)
    net_perm = NeuralNet(arch, mode='octave', seed=seed)
    net_conv = NeuralNet(arch, mode='conv',   seed=seed)

    n_batches = len(X_train) // BATCH_SIZE

    for epoch in range(N_EPOCHS):
        idx = np.random.RandomState(seed + epoch).permutation(len(X_train))
        Xs, ys = X_train[idx], y_train[idx]
        for b in range(n_batches):
            Xb = Xs[b*BATCH_SIZE:(b+1)*BATCH_SIZE]
            yb = ys[b*BATCH_SIZE:(b+1)*BATCH_SIZE]
            net_oct.forward(Xb);  net_oct.backward(Xb,  yb, lr=LR, permuted=False)
            net_perm.forward(Xb); net_perm.backward(Xb, yb, lr=LR, permuted=True)
            net_conv.forward(Xb); net_conv.backward(Xb, yb, lr=LR)

    a_o = net_oct.accuracy(X_val,  y_val)
    a_p = net_perm.accuracy(X_val, y_val)
    a_c = net_conv.accuracy(X_val, y_val)

    res_oct.append(a_o)
    res_perm.append(a_p)
    res_conv.append(a_c)

    genuino = "✅ SIM" if a_o > a_p else "❌ NÃO"
    print(f"{seed:>8} | {a_o:>8.4f} | {a_p:>8.4f} | {a_c:>8.4f} | {genuino:>9}")

# ── Resultados ────────────────────────────────────────────────────────────
oct_arr  = np.array(res_oct)
perm_arr = np.array(res_perm)
conv_arr = np.array(res_conv)

_, p_op = ttest_ind(oct_arr, perm_arr)
_, p_oc = ttest_ind(oct_arr, conv_arr)
wins_op = int(np.sum(oct_arr > perm_arr))
wins_oc = int(np.sum(oct_arr > conv_arr))

