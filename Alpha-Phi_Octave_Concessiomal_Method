# ── Octave Concessional Modulator ─────────────────────────────────────────
def medir_coerencia_oitava(freq_oitava, phi=PHI):
    """
    Mede coerência de amplitude + fase em uma oitava específica.
    Retorna valor entre 0 (ruído total) e 1 (coerência total).
    """
    if freq_oitava.shape[-1] == 0:
        return np.zeros((freq_oitava.shape[0], 1))
    
    # Amplitude
    amplitude = np.abs(freq_oitava)
    amp_norm  = amplitude / (amplitude.sum(axis=-1, keepdims=True) + 1e-8)
    entropia  = -np.sum(amp_norm * np.log(amp_norm + 1e-8), axis=-1, keepdims=True)
    dim       = max(freq_oitava.shape[-1], 2)
    coer_amp  = 1.0 - entropia / np.log(dim)
    
    # Fase — α como trajetória
    fase      = np.angle(freq_oitava)
    resultante = np.sqrt(
        np.cos(fase).mean(axis=-1, keepdims=True)**2 +
        np.sin(fase).mean(axis=-1, keepdims=True)**2
    )
    coer_fase = resultante
    
    # α como operador de granularidade
    peso_phi   = 1.0 - ALPHA
    peso_alpha = ALPHA
    
    return peso_phi * coer_amp + peso_alpha * coer_fase


def octave_concessional_modulator(x, phi=PHI, n_oitavas=4):
    """
    Octave Concessional Method.
    
    Observa o dado em múltiplas oitavas espectrais.
    O que parece ruído numa oitava pode ter coerência em outra.
    
    Concessão: não descarta o dado ruidoso —
    procura a oitava onde ele tem estrutura.
    
    Como o alquimista: muda o paradigma de observação
    até encontrar o nível onde o chumbo é ouro.
    
    x: (batch, dim)
    returns: (batch, 1) modulador per-sample
    """
    freq = np.fft.fft(x, axis=-1)
    n    = x.shape[-1]
    
    # Define as oitavas — divisões progressivas do espectro
    # Fibonacci-like: cada oitava é ~φ vezes maior que a anterior
    limites = []
    inicio  = 0
    tamanho = max(n // (2**n_oitavas), 2)
    for i in range(n_oitavas):
        fim = min(inicio + tamanho * (2**i), n // 2)
        limites.append((inicio, fim))
        inicio = fim
        if inicio >= n // 2:
            break
    
    # Mede coerência em cada oitava
    coerencias = []
    for i, (ini, fim) in enumerate(limites):
        if fim > ini:
            oitava    = freq[:, ini:fim]
            coer      = medir_coerencia_oitava(oitava, phi)
            coerencias.append(coer)
    
    if not coerencias:
        return np.ones((x.shape[0], 1)) * phi * np.tanh(0.5 * phi)
    
    # Stack todas as coerências
    coer_stack = np.concatenate(coerencias, axis=-1)  # (batch, n_oitavas)
    
    # CONCESSÃO: usa a melhor oitava disponível para cada amostra
    # Não descarta — encontra o nível onde o dado tem estrutura
    coer_maxima = coer_stack.max(axis=-1, keepdims=True)  # per-sample
    
    # Média ponderada — oitavas mais baixas têm peso maior (φ)
    pesos = np.array([phi**(-(i+1)) for i in range(len(coerencias))])
    pesos = pesos / pesos.sum()
    coer_media = (coer_stack * pesos).sum(axis=-1, keepdims=True)
    
    # Híbrido: máxima (concessão) + média ponderada (harmonia)
    coer_final = (coer_maxima + coer_media) / 2.0
    
    # Modulador φ
    modulador = phi * np.tanh(coer_final * phi)
    
    return modulador, coer_stack, limites


def relu(x): return np.maximum(0, x)
def relu_deriv(x): return (x > 0).astype(float)
def sigmoid(x): return 1.0 / (1.0 + np.exp(-np.clip(x, -500, 500)))
def clip_grad(g, max_norm=1.0):
    norm = np.linalg.norm(g)
    return g * max_norm / norm if norm > max_norm else g

uniform_layers = [144, 144, 144]

class NeuralNet:
    def __init__(self, layer_sizes, mode='conv', seed=42):
        np.random.seed(seed)
        self.mode    = mode
        self.weights = []
        self.biases  = []
        for i in range(len(layer_sizes)-1):
            scale = np.sqrt(2.0 / layer_sizes[i])
            self.weights.append(np.random.randn(layer_sizes[i], layer_sizes[i+1]) * scale)
            self.biases.append(np.zeros(layer_sizes[i+1]))

    def forward(self, X):
        self.pre_acts = []; self.acts = [X]; cur = X
        for i, (W, b) in enumerate(zip(self.weights, self.biases)):
            is_out = (i == len(self.weights)-1)
            z = cur @ W + b
            cur = sigmoid(z) if is_out else relu(z)
            self.pre_acts.append(z); self.acts.append(cur)
        return cur

    def backward(self, X, y, lr=0.1, permuted=False):
        m = X.shape[0]
        if self.mode == 'octave':
            X_mod = X[np.random.permutation(len(X))] if permuted else X
            mod, _, _ = octave_concessional_modulator(X_mod)
            lr_efetivo = lr * mod.mean()
        else:
            lr_efetivo = lr

        delta = self.acts[-1] - y.reshape(-1, 1)
        for i in reversed(range(len(self.weights))):
            dW = clip_grad(self.acts[i].T @ delta / m, 1.0)
            db = clip_grad(delta.mean(axis=0), 1.0)
            self.weights[i] -= lr_efetivo * dW
            self.biases[i]  -= lr_efetivo * db
            if i > 0:
                delta = (delta @ self.weights[i].T) * relu_deriv(self.pre_acts[i-1])

    def predict(self, X): return (self.forward(X).flatten() >= 0.5).astype(int)
    def accuracy(self, X, y): return np.mean(self.predict(X) == y)

# ── Carregar SST-2 ────────────────────────────────────────────────────────
print("\nCarregando SST-2...")
dataset = load_dataset('glue', 'sst2')
encoder = SentenceTransformer('all-MiniLM-L6-v2')

N_TRAIN = 5000
X_train = encoder.encode(dataset['train']['sentence'][:N_TRAIN],
                         show_progress_bar=True, batch_size=64)
y_train = np.array(dataset['train']['label'][:N_TRAIN])
X_val   = encoder.encode(dataset['validation']['sentence'],
                         show_progress_bar=True, batch_size=64)
y_val   = np.array(dataset['validation']['label'])

mean = X_train.mean(0); std = X_train.std(0) + 1e-8
X_train = (X_train - mean) / std
X_val   = (X_val   - mean) / std
print(f"X_train: {X_train.shape}  X_val: {X_val.shape}")

# ── Diagnóstico das Oitavas ───────────────────────────────────────────────
print("\n=== DIAGNÓSTICO — OCTAVE CONCESSIONAL ===")
sample = X_train[:200]
mod, coer_stack, limites = octave_concessional_modulator(sample)

print(f"Oitavas analisadas: {len(limites)}")
for i, (ini, fim) in enumerate(limites):
    print(f"  Oitava {i+1}: componentes [{ini}:{fim}] "
          f"— coerência média: {coer_stack[:, i].mean():.4f} "
          f"± {coer_stack[:, i].std():.4f}")

print(f"\nModulador Octave Concessional (melhor oitava por amostra):")
print(f"  Média={mod.mean():.4f}  Desvio={mod.std():.4f}")
