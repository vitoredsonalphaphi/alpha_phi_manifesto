# ── Divisão φ-Recursiva de uma Tensão ────────────────────────────────────
def gerar_bandas_phi(n_componentes, n_niveis=4):
    bandas = []
    def dividir(inicio, fim, nivel):
        if nivel == 0 or fim - inicio < 2:
            bandas.append((inicio, fim))
            return
        meio = inicio + int((fim - inicio) / PHI)
        dividir(inicio, meio, nivel - 1)
        dividir(meio, fim, nivel - 1)
    dividir(0, n_componentes, n_niveis)
    return bandas

def medir_coerencia(freq_comp, phi=PHI):
    if freq_comp.shape[-1] < 2:
        return np.zeros((freq_comp.shape[0], 1))
    amplitude = np.abs(freq_comp)
    amp_norm  = amplitude / (amplitude.sum(axis=-1, keepdims=True) + 1e-8)
    entropia  = -np.sum(amp_norm * np.log(amp_norm + 1e-8), axis=-1, keepdims=True)
    coer_amp  = 1.0 - entropia / np.log(max(freq_comp.shape[-1], 2))
    fase       = np.angle(freq_comp)
    resultante = np.sqrt(
        np.cos(fase).mean(axis=-1, keepdims=True)**2 +
        np.sin(fase).mean(axis=-1, keepdims=True)**2
    )
    return (coer_amp + resultante) / 2.0

def phi_tree_modulator(freq_tensao, n_niveis=4, phi=PHI):
    """
    Aplica divisão φ-recursiva a uma tensão específica.
    Retorna modulador combinando coerência ponderada + máxima.
    """
    n      = freq_tensao.shape[-1]
    bandas = gerar_bandas_phi(n, n_niveis)

    coerencias = []
    pesos      = []
    for i, (ini, fim) in enumerate(bandas):
        if fim > ini:
            coer = medir_coerencia(freq_tensao[:, ini:fim], phi)
            coerencias.append(coer)
            pesos.append((1.0 / phi) ** i)

    if not coerencias:
        return np.ones((freq_tensao.shape[0], 1)) * 0.5

    pesos_arr  = np.array(pesos) / sum(pesos)
    coer_stack = np.concatenate(coerencias, axis=-1)

    coer_pond  = (coer_stack * pesos_arr).sum(axis=-1, keepdims=True)
    coer_max   = coer_stack.max(axis=-1, keepdims=True)

    coer_final = (1.0/phi) * coer_pond + (1.0/phi**2) * coer_max
    return phi * np.tanh(coer_final * phi)


def phi_dual_modulator(x, phi=PHI, alpha=ALPHA, n_niveis=4):
    """
    Phi-Dual: φ-Symmetric aplicado às duas tensões separadamente.

    1. Separa espectro em tensão ascendente e descendente
    2. Aplica divisão φ-recursiva em cada tensão independentemente
    3. α como operador de equilíbrio entre as duas árvores
    """
    freq = np.fft.fft(x, axis=-1)
    n    = x.shape[-1]

    # Tensão ASCENDENTE — frequências positivas
    freq_asc  = freq[:, 1:n//2]
    mod_asc   = phi_tree_modulator(freq_asc,  n_niveis, phi)

    # Tensão DESCENDENTE — frequências negativas
    freq_desc = freq[:, n//2:]
    mod_desc  = phi_tree_modulator(freq_desc, n_niveis, phi)

    # α como operador de equilíbrio
    modulador = alpha * mod_asc + (1 - alpha) * mod_desc

    return modulador, mod_asc, mod_desc


def relu(x): return np.maximum(0, x)
def relu_deriv(x): return (x > 0).astype(float)
def sigmoid(x): return 1.0 / (1.0 + np.exp(-np.clip(x, -500, 500)))
def clip_grad(g, max_norm=1.0):
    norm = np.linalg.norm(g)
    return g * max_norm / norm if norm > max_norm else g

uniform_layers = [144, 144, 144]

class NeuralNet:
    def __init__(self, layer_sizes, mode='conv', seed=42):
        np.random.seed(seed)
        self.mode    = mode
        self.weights = []
        self.biases  = []
        for i in range(len(layer_sizes)-1):
            scale = np.sqrt(2.0 / layer_sizes[i])
            self.weights.append(np.random.randn(layer_sizes[i], layer_sizes[i+1]) * scale)
            self.biases.append(np.zeros(layer_sizes[i+1]))

    def forward(self, X):
        self.pre_acts = []; self.acts = [X]; cur = X
        for i, (W, b) in enumerate(zip(self.weights, self.biases)):
            is_out = (i == len(self.weights)-1)
            z = cur @ W + b
            cur = sigmoid(z) if is_out else relu(z)
            self.pre_acts.append(z); self.acts.append(cur)
        return cur

    def backward(self, X, y, lr=0.1, permuted=False):
        m = X.shape[0]
        if self.mode == 'phi_dual':
            X_mod = X[np.random.permutation(len(X))] if permuted else X
            mod, _, _ = phi_dual_modulator(X_mod)
            lr_efetivo = lr * mod.mean()
        else:
            lr_efetivo = lr

        delta = self.acts[-1] - y.reshape(-1, 1)
        for i in reversed(range(len(self.weights))):
            dW = clip_grad(self.acts[i].T @ delta / m, 1.0)
            db = clip_grad(delta.mean(axis=0), 1.0)
            self.weights[i] -= lr_efetivo * dW
            self.biases[i]  -= lr_efetivo * db
            if i > 0:
                delta = (delta @ self.weights[i].T) * relu_deriv(self.pre_acts[i-1])

    def predict(self, X): return (self.forward(X).flatten() >= 0.5).astype(int)
    def accuracy(self, X, y): return np.mean(self.predict(X) == y)

# ── Carregar SST-2 ────────────────────────────────────────────────────────
print("\nCarregando SST-2...")
dataset = load_dataset('glue', 'sst2')
encoder = SentenceTransformer('all-MiniLM-L6-v2')

N_TRAIN = 5000
X_train = encoder.encode(dataset['train']['sentence'][:N_TRAIN],
                         show_progress_bar=True, batch_size=64)
y_train = np.array(dataset['train']['label'][:N_TRAIN])
X_val   = encoder.encode(dataset['validation']['sentence'],
                         show_progress_bar=True, batch_size=64)
y_val   = np.array(dataset['validation']['label'])

mean = X_train.mean(0); std = X_train.std(0) + 1e-8
X_train = (X_train - mean) / std
X_val   = (X_val   - mean) / std
print(f"X_train: {X_train.shape}  X_val: {X_val.shape}")

# ── Diagnóstico ───────────────────────────────────────────────────────────
print("\n=== DIAGNÓSTICO — PHI-DUAL ===")
sample = X_train[:200]
mod, mod_asc, mod_desc = phi_dual_modulator(sample)

print(f"Árvore φ Ascendente:")
print(f"  Modulador: {mod_asc.mean():.4f} ± {mod_asc.std():.4f}")
print(f"Árvore φ Descendente:")
